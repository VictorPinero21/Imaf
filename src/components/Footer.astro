---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const navigation = [
  { label: "Inicio", href: "/" },
  { label: "Mecanizado CNC", href: "/servicios/mecanizado-cnc" },
  { label: "Utillaje Industrial", href: "/servicios/utillaje-industrial" },
  { label: "Sobre nosotros", href: "/sobre-nosotros" },
  { label: "Contacto", href: "/contacto" },
];

const legal = [
  { label: "Aviso Legal", href: "/aviso-legal" },
  { label: "Política de Privacidad", href: "/politica-de-privacidad" },
];
---

<footer class="relative bg-zinc-950 border-t border-zinc-800 overflow-hidden">

  <!-- Grid background sutil -->
  <div class="absolute inset-0 opacity-5"
    style="background-image: linear-gradient(#71717a 1px, transparent 1px), linear-gradient(90deg, #71717a 1px, transparent 1px); background-size: 40px 40px;">
  </div>

  <!-- Accent line top -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-orange-500/50 to-transparent"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-12">

    <!-- Main footer content -->
    <div class="py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Col 1: Logo + descripción -->
      <div class="lg:col-span-2 space-y-6">
        <div>
          <!-- Logo / Nombre -->
          <a href="/" class="inline-flex items-center gap-3 group">
            <div class="w-8 h-8 bg-orange-500 flex items-center justify-center">
              <span class="text-black font-black text-sm" style="font-family: 'Barlow Condensed', sans-serif;">I</span>
            </div>
            <div>
              <div class="text-white font-black text-lg leading-none" style="font-family: 'Barlow Condensed', sans-serif;">IMAF</div>
              <div class="text-zinc-500 text-xs font-mono tracking-widest">MECANIZADOS Y UTILLAJE CLM</div>
            </div>
          </a>
        </div>

        <p class="text-zinc-400 text-sm leading-relaxed max-w-sm" style="font-family: 'DM Sans', sans-serif;">
          Empresa especializada en mecanizado CNC y utillaje industrial en Talavera de la Reina. Más de 20 años fabricando piezas a medida con alta precisión para la industria nacional.
        </p>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/company/imaf-clm"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-zinc-800 hover:border-orange-500/50 bg-zinc-900/50 hover:bg-zinc-900 px-4 py-2.5 transition-all duration-200 group"
        >
          <svg class="w-4 h-4 text-zinc-400 group-hover:text-orange-500 transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="text-zinc-400 group-hover:text-white text-xs font-mono tracking-widest uppercase transition-colors">LinkedIn</span>
        </a>
      </div>

      <!-- Col 2: Navegación -->
      <div class="space-y-6">
        <div class="inline-flex items-center gap-2">
          <div class="w-4 h-px bg-orange-500"></div>
          <span class="text-orange-500 text-xs font-mono tracking-[0.3em] uppercase">Navegación</span>
        </div>
        <ul class="space-y-3">
          {navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-zinc-400 hover:text-white text-sm transition-colors duration-200 inline-flex items-center gap-2 group"
                style="font-family: 'DM Sans', sans-serif;"
              >
                <span class="w-0 group-hover:w-3 h-px bg-orange-500 transition-all duration-200 overflow-hidden"></span>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Contacto + Horario -->
      <div class="space-y-6">
        <div class="inline-flex items-center gap-2">
          <div class="w-4 h-px bg-orange-500"></div>
          <span class="text-orange-500 text-xs font-mono tracking-[0.3em] uppercase">Contacto</span>
        </div>

        <ul class="space-y-4" style="font-family: 'DM Sans', sans-serif;">
          <li>
            <a href="tel:+34925800695" class="group flex items-start gap-3">
              <svg class="w-4 h-4 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span class="text-zinc-400 group-hover:text-white text-sm transition-colors">+34 925 80 06 95</span>
            </a>
          </li>
          <li>
            <a href="mailto:info@maquimaf.es" class="group flex items-start gap-3">
              <svg class="w-4 h-4 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="text-zinc-400 group-hover:text-white text-sm transition-colors">info@maquimaf.es</span>
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-zinc-400 text-sm leading-relaxed">
              C/ Dr. Severo Ochoa, 96R<br />
              45614 Talavera de la Reina
            </span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-orange-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-zinc-400 text-sm leading-relaxed">
              Lun – Vie<br />
              8:00 – 18:00
            </span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t border-zinc-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-zinc-600 text-xs font-mono">
        © {currentYear} Imaf S.L. — B45727732. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-6">
        {legal.map((item) => (
          <a
            href={item.href}
            class="text-zinc-600 hover:text-zinc-400 text-xs font-mono tracking-widest uppercase transition-colors"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

  </div>
</footer>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />