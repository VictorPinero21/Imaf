---
// src/components/Header.astro
import logo from "../../public/logo.png";
import { company, navigation } from "../config/site";
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent"
>
  <!-- Accent line top -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-orange-500/50 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group shrink-0">
        <img
          src="/logo.png"
          alt={`${company.shortName} logo`}
          class="h-8 w-auto"
          width="120"
          height="32"
        />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-8">
        {navigation.slice(0, 5).map((item) => (
          <a
            href={item.href}
            class="text-zinc-400 hover:text-white text-sm font-mono tracking-widest uppercase transition-colors duration-200 relative group"
          >
            {item.label}
            <span class="absolute -bottom-1 left-0 w-0 group-hover:w-full h-px bg-orange-500 transition-all duration-200"></span>
          </a>
        ))}
      </nav>

      <!-- CTA desktop + hamburger móvil -->
      <div class="flex items-center gap-4">
        <a
          href="/contacto"
          class="hidden lg:inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-400 text-black font-bold text-xs tracking-widest uppercase px-5 py-3 transition-all duration-200"
        >
          Presupuesto
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <!-- Hamburger -->
        <button
          id="menuBtn"
          aria-label="Abrir menú"
          aria-expanded="false"
          class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 border border-zinc-700 hover:border-orange-500/50 transition-colors"
        >
          <span id="bar1" class="w-5 h-px bg-white transition-all duration-300 origin-center"></span>
          <span id="bar2" class="w-5 h-px bg-white transition-all duration-300"></span>
          <span id="bar3" class="w-5 h-px bg-white transition-all duration-300 origin-center"></span>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobileMenu"
    class="lg:hidden hidden border-t border-zinc-800 bg-zinc-950/98 backdrop-blur-sm"
  >
    <nav class="max-w-6xl mx-auto px-6 py-8 flex flex-col gap-1">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="flex items-center justify-between text-zinc-300 hover:text-white hover:bg-zinc-900 px-4 py-3 text-sm font-mono tracking-widest uppercase transition-all duration-200 group border-b border-zinc-800/50"
        >
          {item.label}
          <svg class="w-4 h-4 text-zinc-600 group-hover:text-orange-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      ))}

      <a
        href="/contacto"
        class="mt-4 flex items-center justify-center gap-2 bg-orange-500 hover:bg-orange-400 text-black font-bold text-sm tracking-widest uppercase px-6 py-4 transition-all duration-200"
      >
        Solicitar presupuesto
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

      <!-- Contacto rápido móvil -->
      <a
        href="tel:+34925800695"
        class="mt-2 flex items-center justify-center gap-2 border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 text-sm font-mono tracking-widest uppercase px-6 py-3 transition-all duration-200"
      >
        <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {company.phoneDisplay}
      </a>
    </nav>
  </div>
</header>

<!-- Spacer para que el contenido no quede bajo el header fijo -->
<div class="h-20"></div>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />

<script>
  const header = document.getElementById("header")!;
  const menuBtn = document.getElementById("menuBtn")!;
  const mobileMenu = document.getElementById("mobileMenu")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;

  // Scroll: fondo sólido al hacer scroll
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header.classList.add("bg-zinc-950/95", "backdrop-blur-sm", "border-b", "border-zinc-800");
      header.classList.remove("bg-transparent");
    } else {
      header.classList.remove("bg-zinc-950/95", "backdrop-blur-sm", "border-b", "border-zinc-800");
      header.classList.add("bg-transparent");
    }
  });

  // Hamburger toggle
  let isOpen = false;

  menuBtn.addEventListener("click", () => {
    isOpen = !isOpen;
    menuBtn.setAttribute("aria-expanded", String(isOpen));

    if (isOpen) {
      mobileMenu.classList.remove("hidden");
      // Animación barras → X
      bar1.style.transform = "translateY(5px) rotate(45deg)";
      bar2.style.opacity = "0";
      bar3.style.transform = "translateY(-5px) rotate(-45deg)";
    } else {
      mobileMenu.classList.add("hidden");
      bar1.style.transform = "";
      bar2.style.opacity = "";
      bar3.style.transform = "";
    }
  });

  // Cerrar menú al hacer clic en un link
  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      mobileMenu.classList.add("hidden");
      bar1.style.transform = "";
      bar2.style.opacity = "";
      bar3.style.transform = "";
    });
  });
</script>