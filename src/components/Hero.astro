---
// Hero.astro — Imaf · Mecanizado CNC y Utillaje Industrial
// Uso: <Hero /> en tu página index.astro
---

<section class="hero" aria-label="Presentación de Imaf">

  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid"></div>
    <div class="hero__accent"></div>
  </div>

  <div class="hero__inner">

    <div class="hero__label" aria-hidden="true">
      <span class="hero__label-line"></span>
      <span>Castilla-La Mancha · Desde 1998</span>
    </div>

    <h1 class="hero__title">
      Mecanizado CNC<br>
      <em>de precisión</em><br>
      y utillaje industrial
    </h1>

    <p class="hero__subtitle">
      Del prototipo a la serie, con las tolerancias que tu producción exige
      y los plazos que no puedes permitirte incumplir.
    </p>

    <div class="hero__actions">
      <a href="/contacto" class="hero__cta hero__cta--primary">
        Solicita presupuesto sin compromiso
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/servicios" class="hero__cta hero__cta--secondary">
        Ver servicios
      </a>
    </div>

    <div class="hero__stats" role="list" aria-label="Datos de la empresa">
      <div class="hero__stat" role="listitem">
        <span class="hero__stat-number">25+</span>
        <span class="hero__stat-label">Años de experiencia</span>
      </div>
      <div class="hero__stat-divider" aria-hidden="true"></div>
      <div class="hero__stat" role="listitem">
        <span class="hero__stat-number">50K+</span>
        <span class="hero__stat-label">Piezas fabricadas</span>
      </div>
      <div class="hero__stat-divider" aria-hidden="true"></div>
      <div class="hero__stat" role="listitem">
        <span class="hero__stat-number">72h</span>
        <span class="hero__stat-label">Plazo medio de entrega</span>
      </div>
    </div>

  </div>

  <div class="hero__visual" aria-hidden="true">
    <div class="hero__visual-frame">
      <div class="hero__visual-inner">
        <!-- Sustituir por <img src="/img/taller.jpg" alt="Taller de mecanizado CNC Imaf" /> -->
        <div class="hero__visual-placeholder">
          <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="20" y="60" width="160" height="100" rx="4" stroke="currentColor" stroke-width="1"/>
            <rect x="40" y="40" width="60" height="30" rx="2" stroke="currentColor" stroke-width="1"/>
            <circle cx="100" cy="110" r="30" stroke="currentColor" stroke-width="1"/>
            <circle cx="100" cy="110" r="18" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 4"/>
            <line x1="100" y1="80" x2="100" y2="140" stroke="currentColor" stroke-width="0.5"/>
            <line x1="70" y1="110" x2="130" y2="110" stroke="currentColor" stroke-width="0.5"/>
            <rect x="155" y="85" width="15" height="50" rx="2" stroke="currentColor" stroke-width="1"/>
            <text x="100" y="175" text-anchor="middle" font-size="9" fill="currentColor" font-family="monospace" letter-spacing="2">CNC · IMAF</text>
          </svg>
        </div>
        <div class="hero__visual-tag">
          <span class="hero__visual-dot"></span>
          Taller activo
        </div>
      </div>
    </div>
  </div>

</section>

<style>
  /* ─── Tokens ─────────────────────────────────────── */
  .hero {
    --c-bg:        #0a0b0d;
    --c-surface:   #111318;
    --c-border:    #1e2128;
    --c-accent:    #c8a96e;       /* dorado industria */
    --c-accent-dim:#7a6340;
    --c-text:      #e8e6e1;
    --c-muted:     #6b6d75;
    --c-stat:      #f0ede8;
    --ff-display:  'Barlow Condensed', 'Arial Narrow', sans-serif;
    --ff-body:     'DM Sans', 'Helvetica Neue', sans-serif;
    --ff-mono:     'JetBrains Mono', 'Courier New', monospace;

    position: relative;
    min-height: 100svh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 0;
    background: var(--c-bg);
    color: var(--c-text);
    overflow: hidden;
    padding: 0 clamp(1.5rem, 5vw, 5rem);
  }

  /* ─── Fondo ──────────────────────────────────────── */
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--c-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--c-border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.5;
    mask-image: radial-gradient(ellipse 80% 80% at 20% 50%, black 30%, transparent 80%);
  }

  .hero__accent {
    position: absolute;
    top: -20%;
    right: 20%;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,169,110,0.06) 0%, transparent 70%);
  }

  /* ─── Inner (columna izq) ────────────────────────── */
  .hero__inner {
    position: relative;
    z-index: 1;
    padding: clamp(4rem, 10vh, 7rem) 0;
    max-width: 600px;
  }

  /* ─── Label superior ─────────────────────────────── */
  .hero__label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--ff-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-accent);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s ease both;
  }

  .hero__label-line {
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--c-accent);
  }

  /* ─── Título ─────────────────────────────────────── */
  .hero__title {
    font-family: var(--ff-display);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--c-text);
    margin: 0 0 1.5rem;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .hero__title em {
    font-style: normal;
    color: var(--c-accent);
    display: block;
  }

  /* ─── Subtítulo ──────────────────────────────────── */
  .hero__subtitle {
    font-family: var(--ff-body);
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    line-height: 1.65;
    color: var(--c-muted);
    max-width: 48ch;
    margin: 0 0 2.5rem;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  /* ─── CTAs ───────────────────────────────────────── */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3.5rem;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--ff-body);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 3px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .hero__cta--primary {
    background: var(--c-accent);
    color: #0a0b0d;
    padding: 0.875rem 1.5rem;
  }

  .hero__cta--primary:hover {
    background: #d9be88;
    transform: translateY(-1px);
  }

  .hero__cta--primary:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 3px;
  }

  .hero__cta--secondary {
    border: 1px solid var(--c-border);
    color: var(--c-muted);
    padding: 0.875rem 1.25rem;
    background: transparent;
  }

  .hero__cta--secondary:hover {
    border-color: var(--c-accent-dim);
    color: var(--c-text);
  }

  /* ─── Stats ──────────────────────────────────────── */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--c-border);
    animation: fadeUp 0.6s 0.4s ease both;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hero__stat-number {
    font-family: var(--ff-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--c-stat);
    line-height: 1;
  }

  .hero__stat-label {
    font-family: var(--ff-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-muted);
  }

  .hero__stat-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--c-border);
    flex-shrink: 0;
  }

  /* ─── Visual (columna der) ───────────────────────── */
  .hero__visual {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4rem 0 4rem 4rem;
    animation: fadeIn 0.8s 0.3s ease both;
  }

  .hero__visual-frame {
    position: relative;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 4/3;
  }

  .hero__visual-frame::before {
    content: '';
    position: absolute;
    inset: -1px;
    border: 1px solid var(--c-border);
    border-radius: 4px;
  }

  .hero__visual-frame::after {
    content: '';
    position: absolute;
    top: 12px;
    left: 12px;
    right: -12px;
    bottom: -12px;
    border: 1px solid var(--c-border);
    border-radius: 4px;
    z-index: -1;
  }

  .hero__visual-inner {
    width: 100%;
    height: 100%;
    border-radius: 3px;
    overflow: hidden;
    background: var(--c-surface);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Cuando tengas la foto real, quita este bloque */
  .hero__visual-placeholder {
    color: var(--c-border);
    width: 60%;
    opacity: 0.6;
  }

  .hero__visual-placeholder svg {
    width: 100%;
    height: auto;
  }

  /* Cuando tengas foto: img llena el frame */
  .hero__visual-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__visual-tag {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--ff-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-muted);
    background: rgba(10,11,13,0.85);
    padding: 0.4rem 0.75rem;
    border-radius: 2px;
    border: 1px solid var(--c-border);
    backdrop-filter: blur(4px);
  }

  .hero__visual-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse 2s ease infinite;
  }

  /* ─── Animaciones ────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  /* ─── Responsive ─────────────────────────────────── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 0 clamp(1.25rem, 5vw, 2.5rem);
    }

    .hero__inner {
      padding: 5rem 0 2rem;
      max-width: 100%;
    }

    .hero__visual {
      padding: 0 0 4rem;
      justify-content: flex-start;
    }

    .hero__title {
      font-size: clamp(2.5rem, 10vw, 4rem);
    }
  }

  @media (max-width: 480px) {
    .hero__stats {
      gap: 1.25rem;
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__cta {
      justify-content: center;
      text-align: center;
    }
  }

  /* ─── Reduced motion ─────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero__label,
    .hero__title,
    .hero__subtitle,
    .hero__actions,
    .hero__stats,
    .hero__visual { animation: none; }
    .hero__visual-dot { animation: none; }
  }
</style>